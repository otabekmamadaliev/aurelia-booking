# Optional. The app ships with working defaults baked into src/lib/email.js —
# these only need setting to point a deployment at a different EmailJS account.
# EmailJS public keys are publishable by design; there is no secret here.

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx

# Address that receives a copy of every confirmation.
VITE_HOTEL_EMAIL=contact@example.com
